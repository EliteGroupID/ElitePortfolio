# Google Analytics 4 Measurement ID
# Get your Measurement ID from https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps Location Coordinates
# Get coordinates from Google Maps (right-click on location pin → coordinates)
# Format: decimal degrees (e.g., -6.2088 for latitude, 106.8456 for longitude)
NEXT_PUBLIC_MAP_LAT=-6.2088
NEXT_PUBLIC_MAP_LNG=106.8456
